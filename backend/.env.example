APP_NAME="JCA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL du frontend Angular — utilisée pour construire les liens dans les emails
# (questionnaire d'accueil, etc.). Voir CONFIGURATION.md §14.
FRONTEND_URL=http://localhost:4200

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Base de données ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cabinet_avocats
DB_USERNAME=root
DB_PASSWORD=

# --- Sanctum / SPA Angular ---
# Ajoutez ici le(s) domaine(s) depuis lesquels tourne le frontend Angular en dev.
SANCTUM_STATEFUL_DOMAINS=localhost:4200
SESSION_DOMAIN=localhost

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Compte admin créé par le seeder (php artisan db:seed --class=AdminUserSeeder) ---
# Changez ADMIN_PASSWORD avant le premier seed en production.
ADMIN_NAME="Administrateur du cabinet"
ADMIN_EMAIL=admin@jca.ca
ADMIN_PASSWORD=changez-moi-immediatement

# --- Email (factures, confirmations RDV, questionnaire d'accueil) ---
# Voir CONFIGURATION.md §9. En local sans configuration, utilisez le mailer "log"
# pour voir les emails dans storage/logs/laravel.log plutôt que d'échouer.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="contact@jca.ca"
MAIL_FROM_NAME="${APP_NAME}"
